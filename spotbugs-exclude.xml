        null checks before Arrays.fill() in catch blocks
        that wipe sensitive crypto material on error. Dead
        code today but intentional safety net for key data.
    -->
    <Match>
        <Class name="com.wolfssl.provider.jce.WolfSSLKeyStore"/>
        <Method name="decryptKey"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NULL_VALUE"/>
