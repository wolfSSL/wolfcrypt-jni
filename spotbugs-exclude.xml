    <!--
        RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE: Defensive
        null check after switch that always assigns or throws.
    -->
    <Match>
        <Class name="com.wolfssl.provider.jce.WolfCryptCipher"/>
        <Method name="wolfCryptUpdate"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>

    <!--
        EQ_CHECK_FOR_OPERAND_NOT_COMPATIBLE_WITH_THIS:
        Intentional check to reject RSAPrivateCrtKey (a subtype
        of RSAPrivateKey) since CRT and non-CRT keys with the
        same modulus/exponent should not be considered equal.
    -->
    <Match>
        <Class name="com.wolfssl.provider.jce.WolfCryptRSAPrivateKey"/>
        <Method name="equals"/>
        <Bug pattern="EQ_CHECK_FOR_OPERAND_NOT_COMPATIBLE_WITH_THIS"/>
    </Match>

    <!--
        PA_PUBLIC_PRIMITIVE_ATTRIBUTE: WolfCryptDebug.DEBUG is
        an intentional public API for toggling debug output.
    -->
    <Match>
        <Class name="com.wolfssl.provider.jce.WolfCryptDebug"/>
        <Field name="DEBUG"/>
        <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
    </Match>

    <!--
        REC_CATCH_EXCEPTION: Broad catch in WKSPrivateKey(byte[])
        ensures sensitive crypto material is wiped on any error.
    -->
    <Match>
        <Class name="~com\.wolfssl\.provider\.jce\.WolfSSLKeyStore\$WKSPrivateKey"/>
        <Method name="&lt;init&gt;" params="byte[]"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

    <!--
        VA_FORMAT_STRING_USES_NEWLINE: Intentional \n for
        consistent log formatting across platforms.
    -->
    <Match>
        <Class name="~com\.wolfssl\.provider\.jce\.WolfCryptDebug\$WolfCryptFormatter"/>
        <Method name="format"/>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

