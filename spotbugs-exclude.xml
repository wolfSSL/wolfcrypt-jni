    <!--
        NM_CLASS_NAMING_CONVENTION: wc-prefixed inner classes
        registered by name in WolfCryptProvider for JCE
        reflection. Renaming would break the public API.
        Scoped to wc* inner class names only.
    -->
    <Match>
        <Class name="~com\.wolfssl\.provider\.jce\.\w+\$wc\w+"/>
        <Bug pattern="NM_CLASS_NAMING_CONVENTION"/>
    </Match>

    <!--
        NM_METHOD_NAMING_CONVENTION: Fips methods mirror native
        wolfCrypt C API names (e.g. DhAgree = wc_DhAgree).
        WolfCrypt utility methods are established public API.
        Renaming would break existing users.
    -->
    <Match>
        <Class name="com.wolfssl.wolfcrypt.Fips"/>
        <Method name="DhAgree"/>
        <Bug pattern="NM_METHOD_NAMING_CONVENTION"/>
    </Match>
